QWidget#Form {
    background-color: #111827;
}

/* 제목 */
QLabel#label {
    color: #FFFFFF;
    font-size: 34px;
    font-weight: 800;
}

/* 영화 선택 */
QComboBox#cb_title {
    background-color: #1F2937;
    color: #F9FAFB;
    border: 2px solid #6366F1;
    border-radius: 18px;
    padding-left: 20px;
}

QComboBox#cb_title:hover {
    border: 2px solid #8B5CF6;
}

QComboBox#cb_title::drop-down {
    border: none;
    width: 40px;
}

QComboBox#cb_title::down-arrow {
    image: none;
    border: none;
}

QComboBox QAbstractItemView {
    background-color: #111827;
    color: #FFFFFF;
    selection-background-color: #7C3AED;
    selection-color: #FFFFFF;
    border: 2px solid #6366F1;
    outline: none;
}

/* 키워드 입력 */
QLineEdit#le_keyword {
    background-color: #1F2937;
    color: #F9FAFB;
    border: 2px solid #374151;
    border-radius: 18px;
    padding-left: 20px;
}

QLineEdit#le_keyword:focus {
    border: 2px solid #8B5CF6;
}

/* 추천 버튼 */
QPushButton#btn_recommend {
    background-color: #7C3AED;
    color: white;
    border: none;
    border-radius: 20px;
    font-size: 22px;
    font-weight: bold;
}

QPushButton#btn_recommend:hover {
    background-color: #8B5CF6;
}

QPushButton#btn_recommend:pressed {
    background-color: #6D28D9;
}

/* 결과 영역 */
QLabel#lb_recommendation {
    background-color: #1F2937;
    color: #E5E7EB;
    border: 2px solid #374151;
    border-radius: 28px;
    padding: 30px;
    font-size: 18px;
}

